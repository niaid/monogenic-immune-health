knitr::opts_chunk$set(echo = FALSE)
knitr::opts_knit$set(root.dir = normalizePath("../../../.."))
suppressPackageStartupMessages({
library(dplyr)
library(WGCNA)
library(pheatmap)
library(BiocGenerics)
library(Biobase)
library(ComplexHeatmap)
library(knitr)
})
.libPaths("../../../../R_3.4.3_packages")
knitr::opts_chunk$set(echo = FALSE)
knitr::opts_knit$set(root.dir = normalizePath("../../../.."))
suppressPackageStartupMessages({
library(dplyr)
library(pheatmap)
library(BiocGenerics)
library(Biobase)
library(ComplexHeatmap)
library(knitr)
})
MODULES.PATH <- "Data/Microarray/analysis_output/WGCNA/uncorrected/modules.rds"
moduleColors <- readRDS(MODULES.PATH)
#load btms that have already been processed
gene_set <- readRDS("Gene_sets/btm.rds")
##remove gene sets without title because less interpretable
gene_set <- gene_set[!grepl("TBA", names(gene_set))]
#source the enrichment function
source("scripts_nick/util/Enrichment/moduleFisher.R")
#perform the enrichment for each module
datList <- lapply(unique(moduleColors), function(module){
dat <- moduleFisher(module, moduleColors, gene_set, names(moduleColors))
return(dat)
})
names(datList) <- unique(moduleColors)
#print the results
for(i in 4:length(datList)){
dat <- datList[[i]]
dat <- dat[order(dat$p.val),]
dat <- dat[1:20,]
dat$mod <- rownames(dat)
print(names(datList[i]))
print(dat)
}
p.mat <- sapply(datList, function(dat){
x <- dat$p.adj
names(x) <- rownames(dat)
return(x)
}
)
p.mat <- p.mat[apply(p.mat, 1, min) < .1 & !is.na(p.mat[,1]), ]
pheatmap(-log10(p.mat), main = "-log10(fdr)", fontsize_row = 4)
