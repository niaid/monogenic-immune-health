# Load medications
meds = readRDS("../Medications/medications.types.rds")
# Subset to the medications we want
meds = meds[, c("visit_id", "Antibiotic", "Antifungal", "Steroid")]
# Open eset
eset = readRDS('../Data/Somalogic/analysis_output/wgcna_results/scores_sample_level.rds')
# Add meds to eset
eset = add_meds_eset(eset, meds)
# Get design matrix
design = make_design(eset)
# Get list of groups
groups.list = list(conditions = make_condition_groups(),
ai.pid = make_AI_PID_groups())
groups.list
# Make fit
fit = fit_limma(eset, design)
# Get statistics
stats = lapply(groups.list, function(groups) {
stats = lapply(c(FALSE, TRUE), function(cross) {
contrast = make_contrasts_mat(design, groups, cross)
contrast.fit = contrasts.fit(fit, contrast)
ebayes_stats = get_ebayes_stats(contrast.fit)
traditional_stats = get_traditional_stats(contrast.fit)
list(ebayes = ebayes_stats, traditional_stats = traditional_stats)
})
names(stats) = c('versus.healthy', 'versus.all')
return(stats)
})
